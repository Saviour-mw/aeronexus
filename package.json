    description : 'Professional DOCX/PDF template for structured flight-test documentation used by certified test pilots.',
    price       : 14.99,
    fileSize    : '1.4 MB',
    fileName    : 'flight-test-report-template.docx',
    filePath    : null,
    thumb       : null,
    placeholder : true,
    rating      : 4.9,
